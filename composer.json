{
  "name": "sunnysideup/cron-jobs",
  "description": "Silverstripe Module to facilitate complext queued jobs / cron jobs to run.",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "cronjobs",
    "cron",
    "queued jobs",
    "cli",
    "command-line",
    "updates",
    "automatic updates"
  ],
  "license": "BSD-3-Clause",
  "require": {
    "silverstripe/framework": "^5.0",
    "silverstripe/admin": "^2.0",
    "sunnysideup/cms-niceties": "5.x-dev",
    "sunnysideup/yes-no-any-filter": "5.x-dev"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "5.x-dev",
    "silverleague/ideannotator": "*"
  },
  "autoload": {
    "psr-4": {
      "Sunnysideup\\CronJobs\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "client/dist"
    ]
  },
  "bin": [
    "bin/sake-npm-build-cron-jobs.sh",
    "bin/sake-npm-watch-cron-jobs.sh"
  ],
  "authors": [
    {
      "name": "Nicolaas Thiemen Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
